# Production Environment Variables for Render
# Copy these to your Render service environment variables

# MongoDB Atlas connection string (replace with your actual Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/thefolio?retryWrites=true&w=majority

# JWT Secret (use a strong, random secret)
JWT_SECRET=your_super_secure_jwt_secret_here_change_this_in_production

# Port (Render sets this automatically, but you can override)
PORT=10000